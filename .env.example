ANTHROPIC_AUTH_TOKEN=your-token
ANTHROPIC_BASE_URL=https://your-compatible-endpoint
ANTHROPIC_MODEL=your-diagnostic-text-model
QWEN_MODEL=openai/qwen3.6-plus
IMAGE_VISION_CONFIG=~/.image-vision-mcp/config.json
VISION_MAX_TOKENS=64000
VISION_DEFAULT_PROMPT=Please analyze the image content.
CACHE_TTL_HOURS=24
CACHE_MAX_MB=500
CACHE_LOCK_TIMEOUT_MS=5000
IMAGE_FETCH_TIMEOUT_MS=30000
IMAGE_MAX_BYTES=20971520
LOG_LEVEL=info
CALL_LOG_ENABLED=true
CALL_LOG_DIR=~/.image-vision-mcp/call-logs
CALL_LOG_INCLUDE_TEXT=true
DIAGNOSTICS_ENABLED=true
DIAGNOSTICS_MAX_TOKENS=1000
DIAGNOSTICS_TIMEOUT_MS=8000
